{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "audio-visualizer",
  "version": "0.1.0",
  "identifier": "audio-visualizer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
    {
      "label": "main",
      "title": "Audio Visualizer",
      "width": 1280,
      "height": 720,
      "alwaysOnTop": false,
      "fullscreen": false
    },
    {
      "label": "lyrics",
      "title": "Lyrics",
      "width": 600,
      "height": 400,
      "alwaysOnTop": true,
      "visible": false
    }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
